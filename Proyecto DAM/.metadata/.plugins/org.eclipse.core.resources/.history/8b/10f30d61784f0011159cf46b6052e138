    private JTextField styledField(int cols) {
        JTextField f = new JTextField(cols);
        f.setBackground(FIELD_BG);
        f.setForeground(TEXT_INPUT);
        f.setCaretColor(Color.WHITE);
        f.setFont(new Font("SansSerif", Font.PLAIN, 13));
        f.setBorder(BorderFactory.createCompoundBorder(
            new LineBorder(FIELD_BOR, 1, true),
            new EmptyBorder(7, 10, 7, 10)));
        f.addFocusListener(new FocusAdapter() {
            @Override public void focusGained(FocusEvent e) {
                f.setBorder(BorderFactory.createCompoundBorder(
                    new LineBorder(FIELD_BOR_FOCUS, 2, true),
                    new EmptyBorder(6, 9, 6, 9)));
            }
            @Override public void focusLost(FocusEvent e) {
                f.setBorder(BorderFactory.createCompoundBorder(
                    new LineBorder(FIELD_BOR, 1, true),
                    new EmptyBorder(7, 10, 7, 10)));
            }
        });
        return f;
    }

    private JSpinner styledSpinner() {
        JSpinner sp = new JSpinner(new SpinnerDateModel());
        sp.setEditor(new JSpinner.DateEditor(sp, "yyyy-MM-dd"));
        sp.setBackground(FIELD_BG);
        sp.setForeground(TEXT_INPUT);
        sp.setFont(new Font("SansSerif", Font.PLAIN, 13));
        sp.setBorder(BorderFactory.createCompoundBorder(
            new LineBorder(FIELD_BOR, 1, true),
            new EmptyBorder(4, 6, 4, 6)));
        sp.setPreferredSize(new Dimension(130, 34));

        JComponent editor = sp.getEditor();
        editor.setBackground(FIELD_BG);
        editor.setForeground(TEXT_INPUT);
        if (editor instanceof JSpinner.DefaultEditor) {
            JTextField tf = ((JSpinner.DefaultEditor) editor).getTextField();
            tf.setBackground(FIELD_BG);
            tf.setForeground(TEXT_INPUT);
            tf.setCaretColor(Color.WHITE);
            tf.setFont(new Font("SansSerif", Font.PLAIN, 13));
            tf.setBorder(new EmptyBorder(0, 4, 0, 4));
        }
        return sp;
    }

    @SuppressWarnings("serial")
    private JComboBox<String> styledCombo(String[] items) {
        JComboBox<String> cb = new JComboBox<String>(items) {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(COMBO_BG);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 6, 6);
                g2.setColor(COMBO_BOR);
                g2.drawRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 6, 6);
                Object sel = getSelectedItem();
                if (sel != null) {
                    g2.setColor(TEXT_INPUT);
                    g2.setFont(new Font("SansSerif", Font.PLAIN, 13));
                    FontMetrics fm = g2.getFontMetrics();
                    g2.drawString(sel.toString(), 10, (getHeight() + fm.getAscent() - fm.getDescent()) / 2);
                }
                int cx = getWidth() - 16;
                int cy = getHeight() / 2;
                int[] xs = {cx - 4, cx + 4, cx};
                int[] ys = {cy - 2, cy - 2, cy + 3};
                g2.setColor(BLUE);
                g2.fillPolygon(xs, ys, 3);
                g2.dispose();
            }
            @Override public Dimension getPreferredSize() {
                Dimension d = super.getPreferredSize();
                d.height = 34;
                return d;
            }
        };
        cb.setOpaque(false);
        cb.setBorder(BorderFactory.createEmptyBorder());
        cb.setFocusable(false);
        cb.setRenderer(new DefaultListCellRenderer() {
            @Override
            public Component getListCellRendererComponent(JList<?> list, Object value,
                    int index, boolean sel, boolean foc) {
                super.getListCellRendererComponent(list, value, index, sel, foc);
                setBackground(sel ? new Color(60, 70, 120) : COMBO_BG);
                setForeground(sel ? Color.WHITE : TEXT_INPUT);
                setFont(new Font("SansSerif", Font.PLAIN, 13));
                setBorder(new EmptyBorder(6, 10, 6, 10));
                return this;
            }
        });
        cb.addPopupMenuListener(new PopupMenuListener() {
            public void popupMenuWillBecomeVisible(PopupMenuEvent e) {
                Object popup = cb.getUI().getAccessibleChild(cb, 0);
                if (popup instanceof JPopupMenu) {
                    JScrollPane sp = (JScrollPane) ((JPopupMenu) popup).getComponent(0);
                    sp.getViewport().getView().setBackground(COMBO_BG);
                }
            }
            public void popupMenuWillBecomeInvisible(PopupMenuEvent e) {}
            public void popupMenuCanceled(PopupMenuEvent e) {}
        });
        return cb;
    }

    @SuppressWarnings("serial")
    private JButton gradientBtn(String txt,
                                Color c1Start, Color c1End,
                                Color c2Start, Color c2End) {
        JButton b = new JButton(txt) {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                Color start = getModel().isRollover() ? c2Start : c1Start;
                Color end   = getModel().isRollover() ? c2End   : c1End;
                GradientPaint gp = new GradientPaint(0, 0, start, getWidth(), 0, end);
                g2.setPaint(gp);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 10, 10);
                g2.dispose();
                super.paintComponent(g);
            }
        };
        b.setForeground(Color.WHITE);
        b.setFont(new Font("SansSerif", Font.BOLD, 13));
        b.setFocusPainted(false);
        b.setBorderPainted(false);
        b.setContentAreaFilled(false);
        b.setCursor(new Cursor(Cursor.HAND_CURSOR));
        b.setBorder(new EmptyBorder(8, 22, 8, 22));
        return b;
    }

    private void estilizarScrollbar(JScrollBar bar) {
        bar.setPreferredSize(new Dimension(12, 0));
        bar.setOpaque(false);
        bar.setUI(new BasicScrollBarUI() {
            @Override protected JButton createDecreaseButton(int o) { return emptyBtn(); }
            @Override protected JButton createIncreaseButton(int o) { return emptyBtn(); }
            private JButton emptyBtn() {
                JButton b = new JButton();
                b.setPreferredSize(new Dimension(12, 8));
                b.setMinimumSize(new Dimension(12, 8));
                b.setMaximumSize(new Dimension(12, 8));
                b.setOpaque(false);
                b.setContentAreaFilled(false);
                b.setBorderPainted(false);
                return b;
            }
            @Override protected void paintTrack(Graphics g, JComponent c, Rectangle r) {}
            @Override protected void paintThumb(Graphics g, JComponent c, Rectangle r) {
                if (r.isEmpty()) return;
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                int barW = 3;
                int x = r.x + (r.width - barW) / 2;
                g2.setColor(isThumbRollover() ? THUMB_HOV : THUMB_COL);
                g2.fillRoundRect(x, r.y, barW, r.height, barW, barW);
                g2.dispose();
            }
        });
    }

    // ── Lógica de datos ──────────────────────────────────────────

    private void cargarDatos() {
        modeloTabla.setRowCount(0);
        List<Proyecto> proyectos = proyectoDAO.obtenerTodos();
        for (Proyecto p : proyectos) {
            modeloTabla.addRow(new Object[]{
                p.getIdProyecto(),
                p.getNombreProyecto(),
                p.getDescripcion(),
                sdf.format(p.getFechaInicio()),
                sdf.format(p.getFechaFin()),
                p.getEstado()
            });
        }
    }

    private void cargarDatosFormulario(int fila) {
        idSeleccionado = (int) modeloTabla.getValueAt(fila, 0);
        txtNombre.setText((String) modeloTabla.getValueAt(fila, 1));
        txtDescripcion.setText((String) modeloTabla.getValueAt(fila, 2));
        try {
            spinnerFechaInicio.setValue(sdf.parse((String) modeloTabla.getValueAt(fila, 3)));
            spinnerFechaFin.setValue(sdf.parse((String) modeloTabla.getValueAt(fila, 4)));
        } catch (Exception e) { e.printStackTrace(); }
        cbEstado.setSelectedItem(modeloTabla.getValueAt(fila, 5));
    }

    private void limpiarFormulario() {
        idSeleccionado = -1;
        txtNombre.setText("");
        txtDescripcion.setText("");
        spinnerFechaInicio.setValue(new Date());
        spinnerFechaFin.setValue(new Date());
        cbEstado.setSelectedIndex(0);
        tablaProyectos.clearSelection();
    }

    private void guardarProyecto() {
        if (validarCampos()) {
            Proyecto p = new Proyecto(0, txtNombre.getText(), txtDescripcion.getText(),
                (Date) spinnerFechaInicio.getValue(),
                (Date) spinnerFechaFin.getValue(),
                (String) cbEstado.getSelectedItem());
            proyectoDAO.insertar(p);
            JOptionPane.showMessageDialog(this, "Proyecto guardado correctamente");
            cargarDatos();
            limpiarFormulario();
        }
    }

    private void modificarProyecto() {
        if (idSeleccionado == -1) {
            JOptionPane.showMessageDialog(this, "Seleccione un proyecto para modificar",
                "Advertencia", JOptionPane.WARNING_MESSAGE);
            return;
        }
        if (validarCampos()) {
            Proyecto p = new Proyecto(idSeleccionado, txtNombre.getText(), txtDescripcion.getText(),
                (Date) spinnerFechaInicio.getValue(),
                (Date) spinnerFechaFin.getValue(),
                (String) cbEstado.getSelectedItem());
            proyectoDAO.modificar(p);
            JOptionPane.showMessageDialog(this, "Proyecto modificado correctamente");
            cargarDatos();
            limpiarFormulario();
        }
    }

    private void eliminarProyecto() {
        if (idSeleccionado == -1) {
            JOptionPane.showMessageDialog(this, "Seleccione un proyecto para eliminar",
                "Advertencia", JOptionPane.WARNING_MESSAGE);
            return;
        }
        int confirm = JOptionPane.showConfirmDialog(this,
            "¿Está seguro de eliminar este proyecto?",
            "Confirmar eliminación", JOptionPane.YES_NO_OPTION);
        if (confirm == JOptionPane.YES_OPTION) {
            proyectoDAO.eliminar(idSeleccionado);
            JOptionPane.showMessageDialog(this, "Proyecto eliminado correctamente");
            cargarDatos();
            limpiarFormulario();
        }
    }

    private boolean validarCampos() {
        if (txtNombre.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "El nombre del proyecto es obligatorio",
                "Error", JOptionPane.ERROR_MESSAGE);
            return false;
        }
        Date fechaInicio = (Date) spinnerFechaInicio.getValue();
        Date fechaFin    = (Date) spinnerFechaFin.getValue();
        if (fechaFin.before(fechaInicio)) {
            JOptionPane.showMessageDialog(this,
                "La fecha de fin no puede ser anterior a la fecha de inicio",
                "Error", JOptionPane.ERROR_MESSAGE);
            return false;
        }
        return true;
    }
}