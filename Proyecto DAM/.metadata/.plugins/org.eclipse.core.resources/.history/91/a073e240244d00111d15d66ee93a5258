package vista;

import java.awt.*;
import java.awt.geom.*;

import javax.swing.*;
import javax.swing.border.*;
import java.awt.image.BufferedImage;

import conexionBD.ConexionBD;
import dao.EmpleadoDAO;
import dao.LoginDAO;
import dialog.DialogoErrorLogin;
import modelo.Usuario;

public class LoginFrame extends JFrame {

	private static final long serialVersionUID = 1L;
	private JPanel contentPane;
	private ConexionBD conexionBD;
	private EmpleadoDAO empleadoDAO;
	
	private JTextField txtEmail;
    private JPasswordField txtPassword;
    private JButton btnLogin;
    
    // ── PALETA ───────────────────────────────────────────────────
    private static final Color BG_DARK      = new Color(34, 37, 54);
    private static final Color PANEL_BG     = new Color(51, 54, 74);
    private static final Color ACCENT       = new Color(80, 70, 200);
    private static final Color ACCENT_HOVER = new Color(100, 90, 220);
    private static final Color FIELD_BG     = new Color(35, 37, 58);
    private static final Color FIELD_BORDER = new Color(74, 77, 102);
    private static final Color TEXT_PRIMARY = new Color(232, 233, 245);
    private static final Color TEXT_LABEL   = new Color(200, 202, 223);
    private static final Color TEXT_MUTED   = new Color(160, 163, 190);

	/**
	 * Create the frame.
	 */
	public LoginFrame(ConexionBD conexionBD, EmpleadoDAO empleadoDAO) {
		this.conexionBD = conexionBD;
	    this.empleadoDAO = empleadoDAO;
		
		setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
		setBounds(100, 100, 1111, 743);
		
		contentPane = new JPanel();
		contentPane.setBorder(new EmptyBorder(5, 5, 5, 5));
		contentPane.setBackground(BG_DARK);
		contentPane.setLayout(new GridBagLayout());
		setContentPane(contentPane);
		
		initComponents();
	}
	
	@SuppressWarnings("serial")
	private void initComponents() {
		RoundedPanel panelLogin = new RoundedPanel(18);
        panelLogin.setLayout(null);
        panelLogin.setPreferredSize(new Dimension(340, 420));
        panelLogin.setBackground(PANEL_BG);
        contentPane.add(panelLogin);
		
        JLabel avatar = new JLabel() {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setRenderingHint(RenderingHints.KEY_RENDERING, RenderingHints.VALUE_RENDER_QUALITY);

                int size = 68;
                BufferedImage img = new BufferedImage(size, size, BufferedImage.TYPE_INT_ARGB);
                Graphics2D ig = img.createGraphics();
                ig.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                ig.setColor(ACCENT);
                ig.fillOval(0, 0, size, size);
                ig.setColor(new Color(235, 236, 248));
                ig.fillOval(21, 10, 26, 26);
                ig.fillOval(9, 42, 50, 38);
                ig.dispose();
                
                BufferedImage masked = new BufferedImage(size, size, BufferedImage.TYPE_INT_ARGB);
                Graphics2D mg = masked.createGraphics();
                mg.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                mg.setColor(Color.WHITE);
                mg.fillOval(0, 0, size, size);
                mg.setComposite(AlphaComposite.SrcIn);
                mg.drawImage(img, 0, 0, null);
                mg.dispose();
                
                g2.drawImage(masked, 0, 0, null);
                g2.dispose();
            }

            @Override
            public Dimension getPreferredSize() {
                return new Dimension(68, 68);
            }
        };
        avatar.setBounds(136, 20, 68, 68);
        panelLogin.add(avatar);
		
        JLabel lblSubtitle = new JLabel("INICIAR SESIÓN", SwingConstants.CENTER);
        lblSubtitle.setFont(new Font("SansSerif", Font.PLAIN, 11));
        lblSubtitle.setForeground(TEXT_MUTED);
        lblSubtitle.setBounds(0, 100, 340, 20);
        panelLogin.add(lblSubtitle);
		
        JSeparator sep = new JSeparator();
        sep.setForeground(FIELD_BORDER);
        sep.setBackground(FIELD_BORDER);
        sep.setBounds(30, 128, 280, 1);
        panelLogin.add(sep);
		
        JLabel lblEmail = new JLabel("Correo electrónico");
        lblEmail.setBounds(30, 148, 280, 16);
        lblEmail.setForeground(TEXT_LABEL);
        lblEmail.setFont(new Font("SansSerif", Font.PLAIN, 11));
        panelLogin.add(lblEmail);
		
        txtEmail = new JTextField();
        styleField(txtEmail);
        txtEmail.setBounds(30, 168, 280, 38);
        panelLogin.add(txtEmail);
        
        JLabel lblPassword = new JLabel("Contraseña");
        lblPassword.setBounds(30, 220, 280, 16);
        lblPassword.setForeground(TEXT_LABEL);
        lblPassword.setFont(new Font("SansSerif", Font.PLAIN, 11));
        panelLogin.add(lblPassword);
        
        txtPassword = new JPasswordField();
        styleField(txtPassword);
        txtPassword.setBounds(30, 240, 280, 38);
        panelLogin.add(txtPassword);
		
        btnLogin = new JButton("Iniciar sesión") {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(getModel().isRollover() ? ACCENT_HOVER : ACCENT);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 10, 10);
                super.paintComponent(g);
            }
        };
        btnLogin.setBounds(30, 302, 280, 42);
        btnLogin.setForeground(Color.WHITE);
        btnLogin.setFont(new Font("SansSerif", Font.BOLD, 13));
        btnLogin.setFocusPainted(false);
        btnLogin.setBorderPainted(false);
        btnLogin.setContentAreaFilled(false);
        btnLogin.setCursor(new Cursor(Cursor.HAND_CURSOR));
        panelLogin.add(btnLogin);
        
        JLabel lblForgot = new JLabel("¿Olvidaste tu contraseña?", SwingConstants.CENTER);
        lblForgot.setBounds(0, 360, 340, 16);
        lblForgot.setForeground(TEXT_LABEL);
        lblForgot.setFont(new Font("SansSerif", Font.PLAIN, 11));
        panelLogin.add(lblForgot);
		
		btnLogin.addActionListener(e -> {
			String email = txtEmail.getText();
		    String password = new String(txtPassword.getPassword());
		    
		    LoginDAO dao = new LoginDAO(conexionBD);
		    Usuario usuario = dao.login(email, password);
		    
		    if (usuario != null) {
		        if (usuario.getRol().equals("ADMIN")) {
		        	AdminFrame frame = new AdminFrame(empleadoDAO);
		            frame.setVisible(true);
		            this.dispose();
		        } else {
		        	UsuarioFrame frame = new UsuarioFrame(empleadoDAO);
		            frame.setVisible(true);
		            this.dispose();
		        }
		    } else {
		    	new DialogoErrorLogin(this, "Credenciales incorrectas").setVisible(true);
		    }
		});
	}
	
	/** Aplica estilo uniforme a los campos de texto */
    private void styleField(JTextField field) {
        field.setBackground(FIELD_BG);
        field.setForeground(TEXT_PRIMARY);
        field.setCaretColor(TEXT_PRIMARY);
        field.setFont(new Font("SansSerif", Font.PLAIN, 13));
        field.setBorder(BorderFactory.createCompoundBorder(
                new LineBorder(FIELD_BORDER, 1, true),
                new EmptyBorder(0, 10, 0, 10)
        ));
    }
    
    /** Panel con esquinas redondeadas personalizado */
    @SuppressWarnings("serial")
	static class RoundedPanel extends JPanel {
        private final int radius;
        RoundedPanel(int radius) { this.radius = radius; setOpaque(false); }

        @Override
        protected void paintComponent(Graphics g) {
            Graphics2D g2 = (Graphics2D) g;
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            g2.setColor(getBackground());
            g2.fill(new RoundRectangle2D.Double(0, 0, getWidth(), getHeight(), radius * 2, radius * 2));
        }
    }
}