                    c.setBackground(TABLE_SEL); c.setForeground(TEXT_TITLE);
                } else {
                    c.setBackground(row % 2 == 0 ? TABLE_ROW : TABLE_ROW_ALT);
                    c.setForeground(TEXT_INPUT);
