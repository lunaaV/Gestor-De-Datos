        JPanel filtrosWrap = new JPanel(new BorderLayout());
        filtrosWrap.setOpaque(false);
        filtrosWrap.add(filtros, BorderLayout.CENTER);
        filtrosWrap.add(sep(), BorderLayout.SOUTH);
        
        JPanel north = new JPanel(new BorderLayout());
        north.setOpaque(false);
        north.add(headerWrap, BorderLayout.NORTH);
        north.add(filtrosWrap, BorderLayout.SOUTH);
        
        // ── TABLA ───────────────────────────────────────────────
        modelo = new DefaultTableModel() {
            @Override public boolean isCellEditable(int r, int c) { return false; }
        };
        modelo.setColumnIdentifiers(new String[]{
            "ID", "Nombre", "Descripción", "Fecha Inicio", "Fecha Fin", "Estado"});
        
