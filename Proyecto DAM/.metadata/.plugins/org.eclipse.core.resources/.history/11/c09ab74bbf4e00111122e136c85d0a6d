    private void agregarFila(JPanel p, GridBagConstraints gbc, int fila, String label, JComponent field) {
        gbc.gridx = 0; gbc.gridy = fila;
        JLabel lbl = new JLabel(label);
        lbl.setForeground(TEXT_SUB);
        lbl.setFont(new Font("SansSerif", Font.PLAIN, 12));
        p.add(lbl, gbc);
        gbc.gridx = 1;
        p.add(field, gbc);
    }
    
    // ── LÓGICA ───────────────────────────────────────────────────
    private void rellenarFormulario(Empleado e) {
        empleadoSeleccionado = e;
        SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd");
        txtNombre.setText(e.getNombre());
        txtApellido.setText(e.getApellido());
        txtDni.setText(e.getDni());
        txtEmail.setText(e.getEmail());
        txtTelefono.setText(e.getTelefono());
        txtSalario.setText(String.valueOf(e.getSalario()));
        txtFechaNac.setText(sdf.format(e.getFechaNacimiento()));
        txtFechaCon.setText(sdf.format(e.getFechaContratacion()));
        chkActivo.setSelected(e.isActivo());
        
        // Sincronizar combos con el empleado seleccionado
        seleccionarCombo(cbDepartamento, e.getDepartamento().getNombreDepartamento());
        seleccionarCombo(cbPuesto, e.getPuesto().getNombrePuesto());
        seleccionarCombo(cbSede, e.getSede().getNombreSede());
    }
    
    private void seleccionarCombo(JComboBox<String> cb, String valor) {
        for (int i = 0; i < cb.getItemCount(); i++) {
            if (cb.getItemAt(i).equals(valor)) {
                cb.setSelectedIndex(i);
                return;
            }
        }
    }
    
    private void guardar() {
        if (empleadoSeleccionado == null) {
            JOptionPane.showMessageDialog(this, "Selecciona un empleado primero.", "Aviso", JOptionPane.INFORMATION_MESSAGE);
            return;
        }
        try {
            SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd");
            Date fechaNac = sdf.parse(txtFechaNac.getText());
            Date fechaCon = sdf.parse(txtFechaCon.getText());
            
            int idDep  = new DepartamentoDAO(conexionBD).obtenerTodos()
                            .get(cbDepartamento.getSelectedIndex()).getIdDepartamento();
            int idPue  = new PuestoDAO(conexionBD).obtenerTodos()
                            .get(cbPuesto.getSelectedIndex()).getIdPuesto();
            int idSede = new SedeDAO(conexionBD).obtenerTodos()
                            .get(cbSede.getSelectedIndex()).getIdSede();
            
            Empleado modificado = new Empleado(
                    empleadoSeleccionado.getIdEmpleado(),
                    txtNombre.getText(),
                    txtApellido.getText(),
                    txtDni.getText(),
                    txtEmail.getText(),
                    txtTelefono.getText(),
                    fechaNac,
                    fechaCon,
                    Double.parseDouble(txtSalario.getText()),
                    idDep,
                    idPue,
                    idSede,
                    chkActivo.isSelected());
            
            empleadoDAO.modificarEmpleado(modificado);
            JOptionPane.showMessageDialog(this, "Empleado modificado correctamente.", "Éxito", JOptionPane.INFORMATION_MESSAGE);
            cargarTabla();
        } catch (Exception ex) {
            JOptionPane.showMessageDialog(this, "Error al modificar: " + ex.getMessage(), "Error", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    private void cargarTabla() {
        model.setRowCount(0);
        listaEmpleados = empleadoDAO.obtenerTodos();
        for (int i = 0; i < listaEmpleados.size(); i++) {
            Empleado e = listaEmpleados.get(i);
            String[] fila = new String[6];

            fila[0] = String.valueOf(e.getIdEmpleado());
            fila[1] = e.getNombre();
            fila[2] = e.getApellido();
            fila[3] = e.getDni();
            fila[4] = e.getDepartamento().getNombreDepartamento();
            fila[5] = e.getPuesto().getNombrePuesto();

            model.addRow(fila);
        }
    }
    
    private void cargarCombos() {
        DepartamentoDAO depDAO = new DepartamentoDAO(conexionBD);
        PuestoDAO pueDAO = new PuestoDAO(conexionBD);
        SedeDAO sedeDAO = new SedeDAO(conexionBD);
        
        for (int i = 0; i < depDAO.obtenerTodos().size(); i++) {
            cbDepartamento.addItem(
                    depDAO.obtenerTodos().get(i).getNombreDepartamento()
            );
        }
        
        for (int i = 0; i < pueDAO.obtenerTodos().size(); i++) {
            cbPuesto.addItem(
                    pueDAO.obtenerTodos().get(i).getNombrePuesto()
            );
        }
        
        for (int i = 0; i < sedeDAO.obtenerTodos().size(); i++) {
            cbSede.addItem(
                    sedeDAO.obtenerTodos().get(i).getNombreSede()
            );
        }
    }
