package vista.admin;

import dao.*;
import conexionBD.ConexionBD;
import dao.EmpleadoDAO;
import modelo.Departamento;
import modelo.Empleado;
import modelo.Puesto;
import modelo.Sede;

import javax.swing.*;
import javax.swing.table.*;
import java.awt.*;
import java.util.List;

public class ConsultarPanel extends JPanel {

	private static final long serialVersionUID = 1L;
    private JTable table;
    private DefaultTableModel model;
    private JTextField txtBuscar;
    private JComboBox<String> cbDepartamento;
    private JComboBox<String> cbPuesto;
    private JComboBox<String> cbSede;
    private EmpleadoDAO empleadoDAO;
    private static ConexionBD conexionBD = new ConexionBD();
    private List<Empleado> listaEmpleados;
    private List<Departamento> listaDepartamentos;
    private List<Puesto> listaPuestos;
    private List<Sede> listaSedes;
    
    /**
	 * Create the panel.
	 */
    public ConsultarPanel(EmpleadoDAO empleadoDAO) {
        this.empleadoDAO = empleadoDAO;
        setLayout(new BorderLayout());
        
        initComponents();
        cargarCombos();
        cargarTabla();
    }
    
    private void initComponents() {
        // ── FILTROS ──
        JPanel filtros = new JPanel(new FlowLayout(FlowLayout.LEFT, 8, 10));

        txtBuscar = new JTextField(20);
        txtBuscar.setToolTipText("Buscar por nombre, apellido o DNI...");

        cbDepartamento = new JComboBox<>();
        cbDepartamento.addItem("Todos los departamentos");

        cbPuesto = new JComboBox<>();
        cbPuesto.addItem("Todos los puestos");

        cbSede = new JComboBox<>();
        cbSede.addItem("Todas las sedes");

        JButton btnBuscar = new JButton("Buscar");
        btnBuscar.addActionListener(e -> cargarTabla());

        filtros.add(new JLabel("Buscar:"));
        filtros.add(txtBuscar);
        filtros.add(new JLabel("Departamento:"));
        filtros.add(cbDepartamento);
        filtros.add(new JLabel("Puesto:"));
        filtros.add(cbPuesto);
        filtros.add(new JLabel("Sede:"));
        filtros.add(cbSede);
        filtros.add(btnBuscar);

        // ── TABLA ──
        model = new DefaultTableModel() {
            @Override public boolean isCellEditable(int r, int c) {
            	return false;
            }
        };
        model.setColumnIdentifiers(new String[]{
            "ID", "Nombre", "Apellido", "DNI",
            "Email", "Teléfono", "Salario",
            "Departamento", "Puesto", "Sede"});

        table = new JTable(model);
        JScrollPane scroll = new JScrollPane(table);

        add(filtros, BorderLayout.NORTH);
        add(scroll, BorderLayout.CENTER);
    }

    private void cargarTabla() {
        model.setRowCount(0);
        String busqueda = txtBuscar.getText();
        busqueda = busqueda.trim();
        busqueda = busqueda.toLowerCase();
        
        String dep = cbDepartamento.getSelectedItem().toString();
        String pue = cbPuesto.getSelectedItem().toString();
        String sed = cbSede.getSelectedItem().toString();

        listaEmpleados = empleadoDAO.obtenerTodos();

        for (int i = 0; i < listaEmpleados.size(); i++) {
            Empleado e = listaEmpleados.get(i);
            String nombre = e.getNombre().toLowerCase();
            String apellido = e.getApellido().toLowerCase();
            String dni = e.getDni().toLowerCase();

            boolean coincideBusqueda = false;
            if (busqueda.isEmpty()) coincideBusqueda = true;
            if (nombre.contains(busqueda)) coincideBusqueda = true;
            if (apellido.contains(busqueda)) coincideBusqueda = true;
            if (dni.contains(busqueda)) coincideBusqueda = true;
            
            boolean coincideDep = false;
            if (dep.equals("Todos los departamentos")) coincideDep = true;
            if (e.getDepartamento().getNombreDepartamento().equals(dep)) coincideDep = true;
            
            boolean coincidePue = false;
            if (pue.equals("Todos los puestos")) coincidePue = true;
            if (e.getPuesto().getNombrePuesto().equals(pue)) coincidePue = true;
            
            boolean coincideSed = false;
            if (sed.equals("Todas las sedes")) coincideSed = true;
            if (e.getSede().getNombreSede().equals(sed)) coincideSed = true;

            if (coincideBusqueda == true && coincideDep == true && coincidePue == true && coincideSed == true) {
                Object[] fila = new Object[10];
                
                fila[0] = e.getIdEmpleado();
                fila[1] = e.getNombre();
                fila[2] = e.getApellido();
                fila[3] = e.getDni();
                fila[4] = e.getEmail();
                fila[5] = e.getTelefono();
                fila[6] = e.getSalario();
                fila[7] = e.getDepartamento().getNombreDepartamento();
                fila[8] = e.getPuesto().getNombrePuesto();
                fila[9] = e.getSede().getNombreSede();
                
                model.addRow(fila);
            }
        }
    }

    private void cargarCombos() {

        DepartamentoDAO depDAO = new DepartamentoDAO(conexionBD);
        PuestoDAO pueDAO = new PuestoDAO(conexionBD);
        SedeDAO sedeDAO = new SedeDAO(conexionBD);

        listaDepartamentos = depDAO.obtenerTodos();

        for (int i = 0; i < listaDepartamentos.size(); i++) {
            cbDepartamento.addItem(listaDepartamentos.get(i));
        }

        listaPuestos = pueDAO.obtenerTodos();

        for (int i = 0; i < listaPuestos.size(); i++) {
            cbPuesto.addItem(listaPuestos.get(i).getNombrePuesto());
        }

        listaSedes = sedeDAO.obtenerTodos();

        for (int i = 0; i < listaSedes.size(); i++) {
            cbSede.addItem(listaSedes.get(i).getNombreSede());
        }
    }
}