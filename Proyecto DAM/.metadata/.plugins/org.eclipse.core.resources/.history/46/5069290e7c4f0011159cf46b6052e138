    // ── Lógica ──────────────────────────────────────────────────

    private void cargarProyectos() {
        modelProyectos.clear();
        listaProyectos = proyectoDAO.obtenerTodos();
        for (Proyecto p : listaProyectos)
            modelProyectos.addElement(p.getNombreProyecto());
    }

    private void cargarEmpleadosCombo() {
        listaEmpleados = empleadoDAO.obtenerTodos();
        cbEmpleados.removeAllItems();
        for (Empleado e : listaEmpleados)
            cbEmpleados.addItem(e.getNombre() + " " + e.getApellido());
    }

    private void cargarAsignados() {
        modeloTabla.setRowCount(0);
        if (idProyectoSeleccionado == -1) return;
        List<EmpleadoProyecto> lista = epDAO.obtenerPorProyecto(idProyectoSeleccionado);
        for (EmpleadoProyecto ep : lista) {
            // Busca el nombre del empleado en la lista ya cargada
            String nombre   = "";
            String apellido = "";
            for (Empleado e : listaEmpleados) {
                if (e.getIdEmpleado() == ep.getIdEmpleado()) {
                    nombre   = e.getNombre();
                    apellido = e.getApellido();
                    break;
                }
            }
            modeloTabla.addRow(new Object[]{
                ep.getIdEmpleado(),
                nombre,
                apellido,
                ep.getRolProyecto(),
                ep.getHorasAsignadas()
            });
        }
    }

    private void asignar() {
        if (idProyectoSeleccionado == -1) {
            JOptionPane.showMessageDialog(this, "Selecciona un proyecto primero",
                "Advertencia", JOptionPane.WARNING_MESSAGE);
            return;
        }
        int idxEmp = cbEmpleados.getSelectedIndex();
        if (idxEmp < 0) {
            JOptionPane.showMessageDialog(this, "Selecciona un empleado",
                "Advertencia", JOptionPane.WARNING_MESSAGE);
            return;
        }
        if (txtRol.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "El rol es obligatorio",
                "Error", JOptionPane.ERROR_MESSAGE);
            return;
        }
        int horas;
        try {
            horas = Integer.parseInt(txtHoras.getText().trim());
        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this, "Las horas deben ser un número entero",
                "Error", JOptionPane.ERROR_MESSAGE);
            return;
        }
        int idEmp = listaEmpleados.get(idxEmp).getIdEmpleado();
        epDAO.asignar(new EmpleadoProyecto(idEmp, idProyectoSeleccionado,
            txtRol.getText().trim(), horas));
        JOptionPane.showMessageDialog(this, "Empleado asignado correctamente");
        txtRol.setText("");
        txtHoras.setText("");
        cargarAsignados();
    }

    private void desasignar() {
        if (idEmpleadoSeleccionado == -1) {
            JOptionPane.showMessageDialog(this, "Selecciona un empleado de la tabla para desasignar",
                "Advertencia", JOptionPane.WARNING_MESSAGE);
            return;
        }
        int confirm = JOptionPane.showConfirmDialog(this,
            "¿Desasignar este empleado del proyecto?",
            "Confirmar", JOptionPane.YES_NO_OPTION);
        if (confirm == JOptionPane.YES_OPTION) {
            epDAO.desasignar(idEmpleadoSeleccionado, idProyectoSeleccionado);
            JOptionPane.showMessageDialog(this, "Empleado desasignado correctamente");
            idEmpleadoSeleccionado = -1;
            cargarAsignados();
        }
    }

