	// ── HELPERS DE ESTILO ────────────────────────────────────────
    private JSeparator sep() {
        JSeparator s = new JSeparator();
        s.setForeground(BORDER);
        s.setBackground(BORDER);
        return s;
    }

    private void styleField(JTextField f) {
        f.setBackground(FIELD_BG);
        f.setForeground(TEXT_HI);
        f.setCaretColor(TEXT_HI);
        f.setFont(new Font("SansSerif", Font.PLAIN, 13));
        f.setBorder(BorderFactory.createCompoundBorder(
                new LineBorder(FIELD_BOR, 1, true),
                new EmptyBorder(6, 10, 6, 10)));
    }

    @SuppressWarnings("serial")
	private void styleCombo(JComboBox<String> cb) {
        cb.setBackground(FIELD_BG);
        cb.setForeground(TEXT_SUB);
        cb.setFont(new Font("SansSerif", Font.PLAIN, 13));
        cb.setBorder(new LineBorder(FIELD_BOR, 1, true));
        cb.setRenderer(new DefaultListCellRenderer() {
            @Override
            public Component getListCellRendererComponent(JList<?> list, Object value,
                    int index, boolean sel, boolean foc) {
                super.getListCellRendererComponent(list, value, index, sel, foc);
                setBackground(sel ? ACCENT : FIELD_BG);
                setForeground(sel ? Color.WHITE : TEXT_SUB);
                setBorder(new EmptyBorder(6, 10, 6, 10));
                return this;
            }
        });
    }

    @SuppressWarnings("serial")
	private JButton accentBtn(String txt) {
        JButton b = new JButton(txt) {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(getModel().isRollover() ? ACCENT_HOV : ACCENT);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 8, 8);
                super.paintComponent(g);
            }
        };
        b.setForeground(Color.WHITE);
        b.setFont(new Font("SansSerif", Font.BOLD, 13));
        b.setFocusPainted(false);
        b.setBorderPainted(false);
        b.setContentAreaFilled(false);
        b.setCursor(new Cursor(Cursor.HAND_CURSOR));
        b.setBorder(new EmptyBorder(7, 20, 7, 20));
        return b;
    }

    @SuppressWarnings("serial")
	private JButton ghostBtn(String txt) {
        JButton b = new JButton(txt) {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(getModel().isRollover() ? SURFACE : new Color(0, 0, 0, 0));
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 8, 8);
                g2.setColor(FIELD_BOR);
                g2.drawRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 8, 8);
                super.paintComponent(g);
            }
        };
        b.setForeground(TEXT_SUB);
        b.setFont(new Font("SansSerif", Font.PLAIN, 13));
        b.setFocusPainted(false);
        b.setBorderPainted(false);
        b.setContentAreaFilled(false);
        b.setCursor(new Cursor(Cursor.HAND_CURSOR));
        b.setBorder(new EmptyBorder(7, 20, 7, 20));
        return b;
    }
    
    private void estilizarScrollbar(JScrollBar bar) {
        bar.setPreferredSize(new Dimension(12, 0));
        bar.setOpaque(false);
        bar.setUI(new BasicScrollBarUI() {
            @Override protected JButton createDecreaseButton(int o) {
                JButton b = new JButton();
                b.setPreferredSize(new Dimension(12, 8));
                b.setMinimumSize(new Dimension(12, 8));
                b.setMaximumSize(new Dimension(12, 8));
                b.setOpaque(false);
                b.setContentAreaFilled(false);
                b.setBorderPainted(false);
                return b;
            }
            @Override protected JButton createIncreaseButton(int o) {
                JButton b = new JButton();
                b.setPreferredSize(new Dimension(12, 8));
                b.setMinimumSize(new Dimension(12, 8));
                b.setMaximumSize(new Dimension(12, 8));
                b.setOpaque(false);
                b.setContentAreaFilled(false);
                b.setBorderPainted(false);
                return b;
            }
            @Override protected void paintTrack(Graphics g, JComponent c, Rectangle r) {}
            @Override protected void paintThumb(Graphics g, JComponent c, Rectangle r) {
                if (r.isEmpty()) return;
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                int barW = 3, x = r.x + (r.width - barW) / 2;
                g2.setColor(isThumbRollover() ? THUMB_HOV : THUMB_COL);
                g2.fillRoundRect(x, r.y, barW, r.height, barW, barW);
                g2.dispose();
            }
        });
    }

    // ── LÓGICA ─────────────────────────────────────
    private void cargarTabla() {
        model.setRowCount(0);
        String busqueda = txtBuscar.getText().trim().toLowerCase();
        String dep = cbDepartamento.getSelectedItem().toString();
        String pue = cbPuesto.getSelectedItem().toString();
        String sed = cbSede.getSelectedItem().toString();

        empleadoDAO.obtenerTodos().stream()
		        .filter(e -> busqueda.isEmpty() ||
		                e.getNombre().toLowerCase().contains(busqueda) ||
		                e.getApellido().toLowerCase().contains(busqueda) ||
		                e.getDni().toLowerCase().contains(busqueda))
                .filter(e -> dep.equals("Todos los departamentos") ||
                        e.getDepartamento().getNombreDepartamento().equals(dep))
                .filter(e -> pue.equals("Todos los puestos") ||
                        e.getPuesto().getNombrePuesto().equals(pue))
                .filter(e -> sed.equals("Todas las sedes") ||
                        e.getSede().getNombreSede().equals(sed))
                .skip((pagina - 1) * filasPorPagina)
                .limit(filasPorPagina)
                .forEach(e -> model.addRow(new Object[]{
                        e.getIdEmpleado(), e.getNombre(), e.getApellido(),
                        e.getDni(), e.getEmail(), e.getTelefono(), e.getSalario(),
                        e.getDepartamento().getNombreDepartamento(),
                        e.getPuesto().getNombrePuesto(),
                        e.getSede().getNombreSede()
                }));
    }

    private void cargarComboDepartamentos() {
        cbDepartamento.removeAllItems();
        cbDepartamento.addItem("Todos los departamentos");
        DepartamentoDAO departamentoDAO = new DepartamentoDAO(conexionBD);
        List<Departamento> departamentos = departamentoDAO.obtenerTodos();
        for (Departamento d : departamentos) {
            cbDepartamento.addItem(d.getNombreDepartamento());
        }
    }
    
    private void cargarComboPuestos() {
        cbPuesto.removeAllItems();
        cbPuesto.addItem("Todos los puestos");
        PuestoDAO puestoDAO = new PuestoDAO(conexionBD);
        List<Puesto> puestos = puestoDAO.obtenerTodos();
        for (Puesto p : puestos) {
            cbPuesto.addItem(p.getNombrePuesto());
        }
    }
    
    private void cargarComboSedes() {
        cbSede.removeAllItems();
        cbSede.addItem("Todas las sedes");
        SedeDAO sedeDAO = new SedeDAO(conexionBD);
        List<Sede> sedes = sedeDAO.obtenerTodos();
        for (Sede s : sedes) {
            cbSede.addItem(s.getNombreSede());
        }
    }
