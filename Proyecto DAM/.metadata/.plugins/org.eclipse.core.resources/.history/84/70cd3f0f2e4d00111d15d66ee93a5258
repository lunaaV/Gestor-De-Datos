        JPanel headerText = new JPanel();
        headerText.setLayout(new BoxLayout(headerText, BoxLayout.Y_AXIS));
        headerText.setOpaque(false);
        headerText.add(lblTitulo);
        headerText.add(Box.createVerticalStrut(4));
        headerText.add(lblSub);
        header.add(headerText, BorderLayout.WEST);

        JPanel headerWrap = new JPanel(new BorderLayout());
        headerWrap.setOpaque(false);
        headerWrap.add(header, BorderLayout.CENTER);
        headerWrap.add(sep(), BorderLayout.SOUTH);
        contentPane.add(headerWrap, BorderLayout.NORTH);
        
        // ── PANEL FILTROS ────────────────────────────────────────
        JPanel filtros = new JPanel(new FlowLayout(FlowLayout.LEFT, 8, 12));
        filtros.setBackground(BG_DARK);
        filtros.setBorder(new EmptyBorder(0, 20, 0, 20));

        txtBuscar = new JTextField(17);
        txtBuscar.setToolTipText("Buscar por nombre, apellido o DNI...");
        styleField(txtBuscar);

        cbDepartamento = new JComboBox<>();
        cbDepartamento.addItem("Todos los departamentos");
        styleCombo(cbDepartamento);

        cbPuesto = new JComboBox<>();
        cbPuesto.addItem("Todos los puestos");
        styleCombo(cbPuesto);

        cbSede = new JComboBox<>();
        cbSede.addItem("Todas las sedes");
        styleCombo(cbSede);

