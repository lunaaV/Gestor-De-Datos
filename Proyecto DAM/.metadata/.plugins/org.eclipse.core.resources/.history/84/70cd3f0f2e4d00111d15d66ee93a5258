        btnBuscar.addActionListener(e -> { pagina = 1; cargarTabla(); });

        filtros.add(txtBuscar);
        filtros.add(cbDepartamento);
        filtros.add(cbPuesto);
        filtros.add(cbSede);
        filtros.add(btnBuscar);

        JPanel filtrosWrap = new JPanel(new BorderLayout());
        filtrosWrap.setOpaque(false);
        filtrosWrap.add(filtros, BorderLayout.CENTER);
        filtrosWrap.add(sep(), BorderLayout.SOUTH);
        
        // ── TABLA ────────────────────────────────────────────────
        model = new DefaultTableModel() {
            @Override public boolean isCellEditable(int r, int c) { return false; }
        };
        model.setColumnIdentifiers(new String[]{
            "ID", "Nombre", "Apellido", "DNI",
            "Email", "Teléfono", "Salario",
            "Departamento", "Puesto", "Sede"});

        table = new JTable(model);
        table.setBackground(BG);
        table.setForeground(TEXT_HI);
        table.setFont(new Font("SansSerif", Font.PLAIN, 13));
        table.setRowHeight(36);
        table.setShowGrid(false);
        table.setShowHorizontalLines(false);
        table.setShowVerticalLines(false);
        table.setIntercellSpacing(new Dimension(0, 0));
        table.setSelectionBackground(new Color(80, 70, 200, 55));
        table.setSelectionForeground(TEXT_HI);
        table.setFillsViewportHeight(true);
        
        // ── HEADER TABLA ─────────────────────────────────────────
        JTableHeader th = table.getTableHeader();
        th.setBackground(BG_DARK);
        th.setForeground(TEXT_HEAD);
        th.setFont(new Font("SansSerif", Font.BOLD, 11));
        th.setPreferredSize(new Dimension(0, 36));
        th.setBorder(BorderFactory.createEmptyBorder()); // sin borde blanco
        th.setReorderingAllowed(false);

        th.setDefaultRenderer(new DefaultTableCellRenderer() {
            @Override
            public Component getTableCellRendererComponent(JTable t, Object val,
                    boolean sel, boolean foc, int row, int col) {
                JLabel lbl = (JLabel) super.getTableCellRendererComponent(
                        t, val, sel, foc, row, col);
                lbl.setBackground(BG_DARK);
                lbl.setForeground(TEXT_HEAD);
                lbl.setFont(new Font("SansSerif", Font.BOLD, 11));
                lbl.setBorder(new EmptyBorder(0, 14, 0, 14));
                lbl.setText(val != null ? val.toString().toUpperCase() : "");
                return lbl;
            }
        });
        
        // ── RENDERER FILAS ───────────────────────────────────────
        int[] colsSecundarias = {0, 3, 4, 5, 6};
        table.setDefaultRenderer(Object.class, new DefaultTableCellRenderer() {
            @Override
            public Component getTableCellRendererComponent(JTable t, Object val,
                    boolean sel, boolean foc, int row, int col) {
                super.getTableCellRendererComponent(t, val, sel, foc, row, col);
                setBorder(new EmptyBorder(0, 14, 0, 14));
                setFont(new Font("SansSerif", Font.PLAIN, 13));
                
                Color bg = row % 2 == 0 ? BG : ROW_EVEN;
                
                if (sel) {
                    setBackground(new Color(80, 70, 200, 50));
                    setForeground(TEXT_HI);
                } else {
                    setBackground(bg);
                    boolean esSec = false;
                    for (int c : colsSecundarias) if (col == c) { esSec = true; break; }
                    setForeground(esSec ? TEXT_LO : TEXT_HI);
                }
                
                if (col == 7 && val != null) {
                    JPanel cell = new JPanel(new FlowLayout(FlowLayout.LEFT, 0, 0));
                    cell.setBackground(sel ? new Color(80, 70, 200, 50) : (row % 2 == 0 ? BG : ROW_EVEN));
                    JLabel badge = new JLabel(val.toString());
                    badge.setFont(new Font("SansSerif", Font.BOLD, 11));
                    badge.setForeground(BADGE_FG);
                    badge.setBackground(BADGE_BG);
                    badge.setOpaque(true);
                    badge.setBorder(new EmptyBorder(2, 8, 2, 8));
                    cell.add(Box.createHorizontalStrut(14));
                    cell.add(badge);
                    return cell;
                }
                return this;
            }
        });
        
        JScrollPane scroll = new JScrollPane(table);
        scroll.setBorder(BorderFactory.createEmptyBorder());
        scroll.getViewport().setBackground(BG);
        scroll.getViewport().setBorder(null);
        estilizarScrollbar(scroll.getVerticalScrollBar());
        
