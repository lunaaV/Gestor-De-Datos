package dialog;

import java.awt.*;
import javax.swing.*;
import javax.swing.border.EmptyBorder;
import conexionBD.ConexionBD;
import dao.RecuperarPasswordDAO;

public class RecuperarPasswordDialog extends JDialog {
	private static final long serialVersionUID = 1L;

    public RecuperarPasswordDialog(JFrame parent, ConexionBD conexionBD) {
        super(parent, "Recuperar contraseña", true);
        setSize(380, 260);
        setLocationRelativeTo(parent);
        getContentPane().setBackground(new Color(51, 54, 74));
        
        JPanel p = new JPanel(new GridBagLayout());
        p.setBorder(new EmptyBorder(20, 20, 20, 20));
        p.setBackground(new Color(51, 54, 74));
        
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(6, 6, 6, 6);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        gbc.gridx = 0; gbc.gridy = 0; gbc.gridwidth = 2;
        
        JLabel title = new JLabel("Recuperar contraseña", SwingConstants.CENTER);
        title.setForeground(new Color(232, 233, 245));
        title.setFont(new Font("SansSerif", Font.BOLD, 14));
        p.add(title, gbc);
        
        gbc.gridwidth = 1; gbc.gridy++;
        JLabel lblEmail = new JLabel("Correo:");
        lblEmail.setForeground(new Color(200, 202, 223));
        p.add(lblEmail, gbc);
        
        gbc.gridx = 1;
        JTextField txtEmail = new JTextField(18);
        p.add(txtEmail, gbc);
        
        gbc.gridx = 0; gbc.gridy++;
        JLabel lblPass = new JLabel("Nueva contraseña:");
        lblPass.setForeground(new Color(200, 202, 223));
        p.add(lblPass, gbc);
        
        gbc.gridx = 1;
        JPasswordField txtPass = new JPasswordField(18);
        p.add(txtPass, gbc);
        
        gbc.gridx = 0; gbc.gridy++;
        JLabel lblPass2 = new JLabel("Confirmar:");
        lblPass2.setForeground(new Color(200, 202, 223));
        p.add(lblPass2, gbc);
        
        gbc.gridx = 1;
        JPasswordField txtPass2 = new JPasswordField(18);
        p.add(txtPass2, gbc);
        
        gbc.gridx = 0; gbc.gridy++; gbc.gridwidth = 2;
        JButton btn = new JButton("Cambiar contraseña");
        btn.setBackground(new Color(80, 70, 200));
        btn.setForeground(Color.WHITE);
        btn.setFocusPainted(false);
        p.add(btn, gbc);
        
        setContentPane(p);
        
        RecuperarPasswordDAO dao = new RecuperarPasswordDAO(conexionBD);
        btn.addActionListener(e -> {
            String email = txtEmail.getText().trim();
            String pass = new String(txtPass.getPassword());
            String pass2 = new String(txtPass2.getPassword());
            
            if (email.isEmpty() || pass.isEmpty()) {
                JOptionPane.showMessageDialog(this, "Rellena todos los campos.");
                return;
            }
            if (!pass.equals(pass2)) {
                JOptionPane.showMessageDialog(this, "Las contraseñas no coinciden.");
                return;
            }
            if (pass.length() < 4) {
                JOptionPane.showMessageDialog(this, "La contraseña debe tener al menos 4 caracteres.");
                return;
            }
            if (!dao.existeEmail(email)) {
                JOptionPane.showMessageDialog(this, "No existe ningún usuario con ese correo.");
                return;
            }
            if (dao.actualizarPassword(email, pass)) {
                JOptionPane.showMessageDialog(this, "Contraseña actualizada correctamente.");
                dispose();
            } else {
                JOptionPane.showMessageDialog(this, "Error al actualizar la contraseña.");
            }
        });
    }
}