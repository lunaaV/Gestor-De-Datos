package vista;

import java.awt.EventQueue;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;

import javax.swing.*;
import javax.swing.border.EmptyBorder;
import java.awt.*;
import conexionBD.ConexionBD;
import dao.EmpleadoDAO;
import vista.admin.*;

public class AdminFrame extends JFrame {
	
	private static final long serialVersionUID = 1L;
	private static ConexionBD conexionBD = new ConexionBD();
    private EmpleadoDAO empleadoDAO;
    
	/**
	 * Launch the application.
	 */
	public static void main(String[] args) {
		EventQueue.invokeLater(new Runnable() {
			public void run() {
				try {
					conexionBD.abrirConexion();
	                AdminFrame frame = new AdminFrame(new EmpleadoDAO(conexionBD));
	                frame.setVisible(true);
				} catch (Exception e) {
					e.printStackTrace();
				}
			}
		});
	}
	
	/**
	 * Create the frame.
	 */
	public AdminFrame(EmpleadoDAO empleadoDAO) {
		this.empleadoDAO = empleadoDAO;
        setTitle("Panel de Administración");
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setBounds(100, 100, 1111, 743);
        setLayout(new BorderLayout());
        
        initComponents();
	}
	
	private void initComponents() {
		// ── PANEL DERECHO ─────────────────────────────────────
        JPanel panelContenido = new JPanel(new CardLayout());
        panelContenido.add(new ConsultarPanel(empleadoDAO), "Consultar");
        panelContenido.add(new InsertarPanel(empleadoDAO),  "Insertar");
        panelContenido.add(new ModificarPanel(empleadoDAO), "Modificar");
        panelContenido.add(new EliminarPanel(empleadoDAO),  "Eliminar");
        panelContenido.add(new GestionUsuariosPanel(conexionBD), "Gestionar Usuarios");
        panelContenido.add(new ProyectosPanel(conexionBD), "Proyectos");
        panelContenido.add(new AsignacionesPanel(conexionBD), "Asignaciones");
        
        // ── MENÚ LATERAL ──────────────────────────────────────
        JPanel sidebar = new JPanel();
        sidebar.setLayout(new BoxLayout(sidebar, BoxLayout.Y_AXIS));
        sidebar.setPreferredSize(new Dimension(200, 0));
        sidebar.setBackground(new Color(20, 22, 39));
        sidebar.setBorder(new EmptyBorder(20, 12, 20, 12));
        
        JLabel lblMenu = new JLabel("Administración");
        lblMenu.setForeground(new Color(236, 237, 248));
        lblMenu.setFont(new Font("SansSerif", Font.BOLD, 14));
        lblMenu.setAlignmentX(Component.LEFT_ALIGNMENT);
        lblMenu.setBorder(new EmptyBorder(0, 8, 20, 0));
        sidebar.add(lblMenu);
        
        String[] opciones = {"Consultar", "Insertar", "Modificar", "Eliminar", "Gestionar Usuarios", "Proyectos", "Asignaciones"};
        for (String opcion : opciones) {
            JButton btn = menuBtn(opcion);
            btn.addActionListener(e -> {
                CardLayout cl = (CardLayout) panelContenido.getLayout();
                cl.show(panelContenido, opcion);
            });
            sidebar.add(btn);
            sidebar.add(Box.createVerticalStrut(6));
        }
        
        // ── BOTÓN CERRAR SESIÓN ──────────────────────────────────
        sidebar.add(Box.createVerticalGlue());
        
        JButton btnCerrarSesion = cerrarSesionBtn();
        btnCerrarSesion.addActionListener(new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {
                dispose();
                new LoginFrame(conexionBD, empleadoDAO).setVisible(true);
            }
        });
        sidebar.add(btnCerrarSesion);
        
        add(sidebar, BorderLayout.WEST);
        add(panelContenido, BorderLayout.CENTER);
	}
	
    // ── HELPERS DE ESTILO ────────────────────────────────────────
	@SuppressWarnings("serial")
	private JButton menuBtn(String txt) {
	    JButton b = new JButton(txt) {
	        @Override
	        protected void paintComponent(Graphics g) {
	            Graphics2D g2 = (Graphics2D) g;
	            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
	            
	            Color colorFondo;
	            if (getModel().isRollover()) colorFondo = new Color(80, 70, 200);
	            else colorFondo = new Color(31, 34, 56);
	            
	            g2.setColor(colorFondo);
	            g2.fillRoundRect(0, 0, getWidth(), getHeight(), 8, 8);
	            super.paintComponent(g);
	        }
	    };
	    b.setForeground(new Color(200, 202, 223));
	    b.setFont(new Font("SansSerif", Font.PLAIN, 13));
	    b.setFocusPainted(false);
	    b.setBorderPainted(false);
	    b.setContentAreaFilled(false);
	    b.setCursor(new Cursor(Cursor.HAND_CURSOR));
	    b.setBorder(new EmptyBorder(10, 14, 10, 14));
	    b.setMaximumSize(new Dimension(Integer.MAX_VALUE, 40));
	    b.setAlignmentX(Component.LEFT_ALIGNMENT);
	    b.setHorizontalAlignment(SwingConstants.LEFT);
	    return b;
	}
	
	@SuppressWarnings("serial")
	private JButton cerrarSesionBtn() {
	    JButton b = new JButton("Cerrar sesión") {
	        @Override
	        protected void paintComponent(Graphics g) {
	            Graphics2D g2 = (Graphics2D) g;
	            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

	            Color colorFondo;
	            if (getModel().isRollover()) colorFondo = new Color(120, 30, 40);
	            else                         colorFondo = new Color(72, 24, 32);

	            g2.setColor(colorFondo);
	            g2.fillRoundRect(0, 0, getWidth(), getHeight(), 8, 8);
	            super.paintComponent(g);
	        }
	    };
	    b.setForeground(new Color(210, 140, 148));
	    b.setFont(new Font("SansSerif", Font.PLAIN, 13));
	    b.setFocusPainted(false);
	    b.setBorderPainted(false);
	    b.setContentAreaFilled(false);
	    b.setCursor(new Cursor(Cursor.HAND_CURSOR));
	    b.setBorder(new EmptyBorder(10, 14, 10, 14));
	    b.setMaximumSize(new Dimension(Integer.MAX_VALUE, 40));
	    b.setAlignmentX(Component.LEFT_ALIGNMENT);
	    b.setHorizontalAlignment(SwingConstants.LEFT);
	    return b;
	}
}